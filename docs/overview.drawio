<mxfile host="app.diagrams.net" type="device"><diagram name="overview" id="sfn-toolkit-overview"><mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="700" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="graph" value="" style="shape=image;imageAspect=0;aspect=fixed;verticalLabelPosition=bottom;verticalAlign=top;labelBackgroundColor=#ffffff;image=data:image/svg+xml;base64," vertex="1" parent="1"><mxGeometry x="120" y="90" width="264" height="495" as="geometry"/></mxCell><mxCell id="title" value="One real Step Functions workflow — run it end-to-end, locally" style="text;html=1;align=center;verticalAlign=middle;fontSize=17;fontStyle=1;fontColor=#0f141a;" vertex="1" parent="1"><mxGeometry x="200" y="28" width="620" height="26" as="geometry"/></mxCell><mxCell id="subtitle" value="The toolkit walks the states and decides, per step, how to execute it." style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="200" y="56" width="620" height="20" as="geometry"/></mxCell><mxCell id="ring_b1" value="" style="rounded=1;fillColor=none;strokeWidth=2;dashed=1;dashPattern=6 4;html=1;strokeColor=#1E88E5" vertex="1" parent="1"><mxGeometry x="126" y="175" width="252" height="64" as="geometry"/></mxCell><mxCell id="ring_b2" value="" style="rounded=1;fillColor=none;strokeWidth=2;dashed=1;dashPattern=6 4;html=1;strokeColor=#1E88E5" vertex="1" parent="1"><mxGeometry x="126" y="262" width="252" height="64" as="geometry"/></mxCell><mxCell id="ring_cf" value="" style="rounded=1;fillColor=none;strokeWidth=2;dashed=1;dashPattern=6 4;html=1;strokeColor=#8E24AA" vertex="1" parent="1"><mxGeometry x="126" y="349" width="252" height="64" as="geometry"/></mxCell><mxCell id="ring_lam" value="" style="rounded=1;fillColor=none;strokeWidth=2;dashed=1;dashPattern=6 4;html=1;strokeColor=#FB8C00" vertex="1" parent="1"><mxGeometry x="126" y="436" width="252" height="64" as="geometry"/></mxCell><mxCell id="stub1" style="endArrow=none;html=1;rounded=0;strokeWidth=1.5;strokeColor=#1E88E5" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="378" y="207" as="sourcePoint"/><mxPoint x="386" y="207" as="targetPoint"/></mxGeometry></mxCell><mxCell id="stub2" style="endArrow=none;html=1;rounded=0;strokeWidth=1.5;strokeColor=#1E88E5" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="378" y="294" as="sourcePoint"/><mxPoint x="386" y="294" as="targetPoint"/></mxGeometry></mxCell><mxCell id="vbar" style="endArrow=none;html=1;rounded=0;strokeWidth=1.5;strokeColor=#1E88E5" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="386" y="200" as="sourcePoint"/><mxPoint x="386" y="301" as="targetPoint"/></mxGeometry></mxCell><mxCell id="lead_b" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;strokeColor=#1E88E5" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="386" y="250" as="sourcePoint"/><mxPoint x="448" y="250" as="targetPoint"/></mxGeometry></mxCell><mxCell id="lead_cf" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;strokeColor=#8E24AA" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="378" y="381" as="sourcePoint"/><mxPoint x="448" y="381" as="targetPoint"/></mxGeometry></mxCell><mxCell id="lead_lam" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;strokeColor=#FB8C00" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="378" y="468" as="sourcePoint"/><mxPoint x="448" y="468" as="targetPoint"/></mxGeometry></mxCell><mxCell id="bracket" style="endArrow=none;html=1;rounded=0;strokeWidth=1.5;strokeColor=#2E7D32" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="122" y="124" as="sourcePoint"/><mxPoint x="122" y="551" as="targetPoint"/><Array as="points"><mxPoint x="100" y="124"/><mxPoint x="100" y="551"/></Array></mxGeometry></mxCell><mxCell id="brak_label" value="walk order: each state's output → next state's input" style="text;html=1;align=center;verticalAlign=middle;rotation=-90;fontSize=11;fontColor=#2E7D32;" vertex="1" parent="1"><mxGeometry x="-32" y="327" width="240" height="20" as="geometry"/></mxCell><mxCell id="call_b" value="&lt;b&gt;Batch submitJob.sync ×2&lt;/b&gt;&lt;br&gt;test_state can't execute .sync steps. The toolkit runs each via a strategy — e.g. DockerBatchStrategy builds &amp;amp; runs the job's container locally. No deploy, no AWS Batch needed." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingRight=8;spacingTop=6;fontSize=12;strokeColor=#1E88E5;fillColor=#E3F2FD;" vertex="1" parent="1"><mxGeometry x="450" y="210" width="490" height="82" as="geometry"/></mxCell><mxCell id="call_cf" value="&lt;b&gt;startExecution.sync:2 — nested state machine&lt;/b&gt;&lt;br&gt;The runner recurses into the child's ASL and walks it the same way (register the child under asl_registry)." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingRight=8;spacingTop=6;fontSize=12;strokeColor=#8E24AA;fillColor=#F3E5F5;" vertex="1" parent="1"><mxGeometry x="450" y="352" width="490" height="58" as="geometry"/></mxCell><mxCell id="call_lam" value="&lt;b&gt;lambda:invoke — ordinary engine step&lt;/b&gt;&lt;br&gt;test_state applies the input/output processing; you supply its result with a CallableStrategy or a static mock." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingRight=8;spacingTop=6;fontSize=12;strokeColor=#FB8C00;fillColor=#FFF3E0;" vertex="1" parent="1"><mxGeometry x="450" y="440" width="490" height="58" as="geometry"/></mxCell><mxCell id="legend" value="&lt;b&gt;How each state is handled&lt;/b&gt;&lt;br&gt;&lt;font color='#FB8C00'&gt;■&lt;/font&gt; test_state runs the engine I/O (InputPath / Arguments / ResultSelector / Output)&lt;br&gt;&lt;font color='#1E88E5'&gt;■&lt;/font&gt; a strategy executes the step locally: Docker, subprocess, your function, mock, real AWS&lt;br&gt;&lt;font color='#8E24AA'&gt;■&lt;/font&gt; recursion into subflows / Map / Parallel&lt;br&gt;&lt;font color='#2E7D32'&gt;■&lt;/font&gt; each state's output feeds the next state's input" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontSize=11;strokeColor=#BDBDBD;fillColor=#FAFAFA;" vertex="1" parent="1"><mxGeometry x="450" y="520" width="490" height="116" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>