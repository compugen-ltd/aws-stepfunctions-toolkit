{
    "Comment": "Run a real Lambda container image locally via the Runtime Interface Emulator",
    "StartAt": "double_it",
    "States": {
        "double_it": {
            "Type": "Task",
            "Resource": "arn:aws:states:::lambda:invoke",
            "QueryLanguage": "JSONata",
            "End": true,
            "Arguments": {
                "FunctionName": "arn:aws:lambda:us-east-1:000000000000:function:echo_lambda",
                "Payload": {
                    "number": "{% $states.input.number %}"
                }
            },
            "Output": "{% $states.result.Payload %}"
        }
    }
}
