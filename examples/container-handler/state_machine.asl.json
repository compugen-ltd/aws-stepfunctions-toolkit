{
    "Comment": "One Batch step whose container code uses BatchJobInterface.",
    "StartAt": "RunJob",
    "States": {
        "RunJob": {
            "Type": "Task",
            "Resource": "arn:aws:states:::batch:submitJob.sync",
            "QueryLanguage": "JSONata",
            "Arguments": {
                "JobDefinition": "arn:aws:batch:us-east-1:000000000000:job-definition/handler-job",
                "JobQueue": "arn:aws:batch:us-east-1:000000000000:job-queue/handler-queue",
                "JobName": "handler-job",
                "ContainerOverrides": {
                    "Command": [
                        "{% $string($states.input) %}"
                    ],
                    "Environment": [
                        {
                            "Name": "ExecutionName",
                            "Value": "{% $states.context.Execution.Name %}"
                        }
                    ]
                }
            },
            "Output": "{% $parse($states.result) %}",
            "End": true
        }
    }
}
